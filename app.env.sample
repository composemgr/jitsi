# Jitsi app.env.sample
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=myhostname
BASE_DOMAIN_NAME=example.com

# Let's Encrypt
LETSENCRYPT_EMAIL=ssl-admin@example.com

# JWT app credentials
APP_API_TOKEN=my_jitsi_app_id
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Internal component passwords (must all be unique)
JICOFO_AUTH_PASSWORD=changeme_jicofo_password
JVB_AUTH_PASSWORD=changeme_jvb_password
JIGASI_SIP_PASSWORD=changeme_sip_password
JIGASI_XMPP_PASSWORD=changeme_jigasi_xmpp_password
JIGASI_TRANSCRIBER_PASSWORD=changeme_transcriber_password
JIBRI_RECORDER_PASSWORD=changeme_jibri_recorder_password
JIBRI_XMPP_PASSWORD=changeme_jibri_xmpp_password
